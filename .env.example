# API key
SECRET_API_KEY=thepasswordyoudontwantotherstoknow

# JWT Bearer Auth
JWT_SECRET_KEY=please_change_this_to_something_random_and_long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15

# Login for the OAuth2 token endpoint
JWT_USERNAME=admin
JWT_PASSWORD=supersecretpassword

# Debug mode
DEBUG=true

# Models
MODEL_REPO=https://github.com/schutera/pixelwise-model.git
MODEL_VERSION=v1.0
MODEL_PATH=models/digit_classifier_v1.pkl

# Database
# DB_PASSWORD is the single database secret. The app assembles the
# connection string from it in app/models.py. Do not add a DATABASE_URL
# with ${DB_PASSWORD} here: systemd's EnvironmentFile passes ${...}
# through literally, so the service would try to authenticate with the
# string "${DB_PASSWORD}" and fail.
DB_PASSWORD=db_password
